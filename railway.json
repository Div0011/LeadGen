{
  "name": "leadgen",
  "version": 1,
  "database": {
    "plan": "free",
    "name": "leadgen_db"
  },
  "services": [
    {
      "name": "backend",
      "github": {
        "repo": "Div0011/LeadGen",
        "branch": "main"
      },
      "rootDir": "backend",
      "dockerfilePath": "docker/Dockerfile.backend",
      "buildCommand": "pip install --no-cache-dir asyncpg && pip install --no-cache-dir -r requirements.txt",
      "startCommand": "python -m uvicorn app.main:app --host 0.0.0.0 --port $PORT",
      "env": {
        "DATABASE_URL": {
          "from": {
            "service": "database",
            "attr": "DATABASE_URL"
          }
        }
      }
    }
  ]
}
