{
  "name": "leadgen",
  "version": 1,
  "database": {
    "plan": "free",
    "name": "leadgen_db"
  },
  "services": [
    {
      "name": "backend",
      "github": {
        "repo": "Div0011/LeadGen",
        "branch": "main",
        "rootDir": "backend"
      },
      "dockerfile": {
        "path": "docker/Dockerfile.backend"
      },
      "env": {
        "DATABASE_URL": {
          "from": {
            "service": "database",
            "attr": "DATABASE_URL"
          }
        }
      },
      "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port $PORT"
    }
  ]
}
