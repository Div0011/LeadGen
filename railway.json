{
  "name": "leadgen",
  "version": 1,
  "database": {
    "plan": "free",
    "name": "leadgen_db"
  },
  "build": {
    "builder": "DOCKERFILE",
    "dockerfile": "docker/Dockerfile.backend"
  },
  "services": [
    {
      "name": "backend",
      "github": {
        "repo": "Div0011/LeadGen",
        "branch": "main"
      },
      "sourceDir": "backend",
      "dockerfile": "docker/Dockerfile.backend",
      "env": {
        "DATABASE_URL": {
          "from": {
            "service": "database",
            "attr": "DATABASE_URL"
          }
        }
      }
    }
  ]
}
