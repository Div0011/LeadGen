# Application
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/leadgen
REDIS_URL=redis://redis:6379/0
SECRET_KEY=your-secret-key-change-in-production
DEBUG=true

# Google APIs
GOOGLE_SHEETS_CREDENTIALS_PATH=config/credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_GMAIL_CREDENTIALS_PATH=config/credentials.json

# Email Validation
HUNTER_IO_API_KEY=
ZERO_BOUNCE_API_KEY=

# SMTP (alternative to Gmail API)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Search API
SERPAPI_API_KEY=

# Agency
AGENCY_NAME=Your Video Marketing Agency
AGENCY_WEBSITE=https://youragency.com
AGENCY_EMAIL=hello@youragency.com
BROCHURE_PATH=data/Brochure.pdf

# Target
TARGET_INDUSTRY=E-commerce startups
TARGET_LOCATION=United States

# Email
EMAIL_FROM_NAME=Your Name
EMAIL_SUBJECT=Quick question about {company}'s video strategy

# Monitoring
CHECK_INTERVAL_MINUTES=15
